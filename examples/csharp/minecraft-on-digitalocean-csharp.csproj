<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- The generated SDK under sdks/ is referenced as a project; don't also compile its sources here. -->
    <Compile Remove="sdks/**/*.cs" />
    <Content Remove="sdks/**" />
    <None Remove="sdks/**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Pulumi" Version="3.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="sdks\minecraft-minecraft\Minecraft.Minecraft.csproj" />
  </ItemGroup>

</Project>
